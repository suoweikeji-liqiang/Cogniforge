# Test Environment Configuration
# Copy to test.env and fill in your API keys

# Qwen (通义千问) API Key for real LLM integration tests
QWEN_API_KEY=sk-xxx
QWEN_MODEL=qwen-plus

# Optional: OpenAI for comparison tests
OPENAI_API_KEY=sk-xxx

# Optional: Anthropic for comparison tests
ANTHROPIC_API_KEY=sk-ant-xxx

# Default provider for tests
DEFAULT_LLM_PROVIDER=qwen
